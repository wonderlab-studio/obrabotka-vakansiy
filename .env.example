GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_LITE=gemini-2.5-flash-lite

# Облачная Ollama (https://ollama.com) — третий шаг цепочки фолбэков, перед локальной Ollama.
# Ключ создаётся на https://ollama.com/settings/keys. Модели там называются с суффиксом
# "-cloud" (см. https://ollama.com/search?c=cloud), укажите ту, что доступна на вашем аккаунте.
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_MODEL=gpt-oss:120b-cloud

OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
PORT=3000
