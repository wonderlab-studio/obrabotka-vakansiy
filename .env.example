# Фолбэк-цепочка LLM (см. requirements.md, раздел 5.6):
# Уровень A (гонка) — Groq + Cerebras параллельно, резерв — Gemini.
#   Для промпта 5.5.2 (сопоставление тезисов) Groq в цепочке не участвует — хуже соблюдает
#   строгое лексическое правило совпадения, см. requirements.md 5.6.
# Уровень B — Mistral, резерв — Cohere.
# Уровень C — OpenRouter, резерв — GitHub Models.
# Финальный резерв — облачная Ollama.
# Если ключ для какого-то звена не задан — оно просто пропускается без сетевого запроса.

# Уровень A
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

CEREBRAS_API_KEY=
CEREBRAS_MODEL=gpt-oss-120b

# Резерв уровня A
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Уровень B
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# Резерв уровня B
COHERE_API_KEY=
COHERE_MODEL=command-r-plus

# Уровень C — ключ на https://openrouter.ai/keys (самостоятельная регистрация, без вейтлиста)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Резерв уровня C — токен из https://github.com/settings/tokens с правом "models: read"
GITHUB_MODELS_TOKEN=
GITHUB_MODELS_MODEL=openai/gpt-4o-mini

# Финальный резерв — облачная Ollama (https://ollama.com/settings/keys), платный ключ.
# Модели там называются с суффиксом "-cloud" (см. https://ollama.com/search?c=cloud).
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_MODEL=gpt-oss:120b-cloud

PORT=3000
